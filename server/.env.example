PORT=5000
MONGODB_URI=mongodb://localhost:27017
DB_NAME=restaurant
CLIENT_URL=http://localhost:3000

# Stripe (optional — enables card payments on /bill/[id])
# Create keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From Stripe CLI: stripe listen --forward-to localhost:5000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
